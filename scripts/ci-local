#!/bin/bash
# Local CI entrypoint with tiered workflows.
#
# Tiers:
#   fast   - quick checks for pre-commit
#   medium - deeper validation for pre-push
#   full   - full local suite (and optional docker cross-arch matrix)
#
# Examples:
#   scripts/ci-local --tier fast
#   scripts/ci-local --tier medium
#   scripts/ci-local --tier full
#   scripts/ci-local --tier full --cross

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

TIER="medium"
RUN_CROSS="auto"
RUN_PERF="no"
RUN_QUALITY_SMOKE="yes"
RUN_STRICT_CALLBACK="yes"
RUN_FEATURE_MATRIX="yes"
RUN_FUZZ_TARGETS="yes"
RUN_SECURITY="yes"
RUN_COVERAGE="yes"
RUN_TLA="yes"
RUN_MEMORY_SAFETY="yes"

usage() {
    cat <<'EOF'
Usage: scripts/ci-local [--tier fast|medium|full] [--cross] [--no-cross] [--perf] [--no-perf] [--quality-smoke] [--no-quality-smoke] [--strict-callback] [--no-strict-callback] [--feature-matrix] [--no-feature-matrix] [--fuzz-targets] [--no-fuzz-targets] [--security] [--no-security] [--coverage] [--no-coverage] [--tla] [--no-tla] [--memory-safety] [--no-memory-safety] [--help]

  --tier      Select workflow tier (default: medium)
  --cross     Force docker cross-arch matrix during full tier
  --no-cross  Disable docker cross-arch matrix during full tier
  --perf      Run deterministic benchmark gate during full tier
  --no-perf   Skip deterministic benchmark gate during full tier (default)
  --quality-smoke     Run fast fixture-backed decompiler quality smoke test (default)
  --no-quality-smoke  Skip fast fixture-backed decompiler quality smoke test
  --strict-callback     Enforce strict callback typing snapshot checks (default)
  --no-strict-callback  Skip strict callback typing snapshot checks
  --feature-matrix     Check non-default feature combinations (default)
  --no-feature-matrix  Skip non-default feature checks
  --fuzz-targets     Check that fuzz targets compile (default)
  --no-fuzz-targets  Skip fuzz target compile checks
  --security     Run `cargo audit` during full tier (default)
  --no-security  Skip security auditing during full tier
  --coverage     Run `cargo llvm-cov` during full tier (default)
  --no-coverage  Skip coverage gate during full tier
  --tla     Run the TLA+ model/conformance gate during full tier (default)
  --no-tla  Skip the TLA+ model/conformance gate during full tier
  --memory-safety     Run the Miri memory-safety gate during full tier (default)
  --no-memory-safety  Skip the Miri memory-safety gate during full tier
  --help      Show this message
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --tier)
            TIER="${2:-}"
            shift 2
            ;;
        --cross)
            RUN_CROSS="yes"
            shift
            ;;
        --no-cross)
            RUN_CROSS="no"
            shift
            ;;
        --perf)
            RUN_PERF="yes"
            shift
            ;;
        --no-perf)
            RUN_PERF="no"
            shift
            ;;
        --quality-smoke)
            RUN_QUALITY_SMOKE="yes"
            shift
            ;;
        --no-quality-smoke)
            RUN_QUALITY_SMOKE="no"
            shift
            ;;
        --strict-callback)
            RUN_STRICT_CALLBACK="yes"
            shift
            ;;
        --no-strict-callback)
            RUN_STRICT_CALLBACK="no"
            shift
            ;;
        --feature-matrix)
            RUN_FEATURE_MATRIX="yes"
            shift
            ;;
        --no-feature-matrix)
            RUN_FEATURE_MATRIX="no"
            shift
            ;;
        --fuzz-targets)
            RUN_FUZZ_TARGETS="yes"
            shift
            ;;
        --no-fuzz-targets)
            RUN_FUZZ_TARGETS="no"
            shift
            ;;
        --security)
            RUN_SECURITY="yes"
            shift
            ;;
        --no-security)
            RUN_SECURITY="no"
            shift
            ;;
        --coverage)
            RUN_COVERAGE="yes"
            shift
            ;;
        --no-coverage)
            RUN_COVERAGE="no"
            shift
            ;;
        --tla)
            RUN_TLA="yes"
            shift
            ;;
        --no-tla)
            RUN_TLA="no"
            shift
            ;;
        --memory-safety)
            RUN_MEMORY_SAFETY="yes"
            shift
            ;;
        --no-memory-safety)
            RUN_MEMORY_SAFETY="no"
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage
            exit 2
            ;;
    esac
done

run() {
    echo ""
    echo "=== $1 ==="
    shift
    "$@"
}

run_fast() {
    run "Formatting" cargo fmt --all --check
    run "Workspace check" cargo check --workspace --all-targets
}

run_medium() {
    run_fast
    run "Clippy (warnings as errors)" cargo clippy --workspace --all-targets --all-features -- -D warnings
    if [[ "$RUN_FEATURE_MATRIX" == "yes" ]]; then
        run "Feature matrix" "$ROOT_DIR/scripts/check-feature-matrix"
    fi
    if [[ "$RUN_FUZZ_TARGETS" == "yes" ]]; then
        run "Fuzz target build" "$ROOT_DIR/scripts/check-fuzz-targets"
        # `medium` only verifies fuzz targets compile. `full` runs each
        # target briefly against its committed corpus to catch crash
        # regressions — see `run_full`.
    fi
    if [[ "$RUN_QUALITY_SMOKE" == "yes" ]]; then
        if [[ "$RUN_STRICT_CALLBACK" == "yes" ]]; then
            run "Decompiler quality smoke (control-flow + strict callback)" "$ROOT_DIR/scripts/quality-smoke" --strict-callback
        else
            run "Decompiler quality smoke (control-flow only)" "$ROOT_DIR/scripts/quality-smoke"
        fi
    elif [[ "$RUN_STRICT_CALLBACK" == "yes" ]]; then
        run "Strict callback typing regressions" env HEXRAY_STRICT_CALLBACK_TYPING=1 cargo test -p hexray --test cli_tests callback
    fi
    run "Workspace unit/integration tests" cargo test --workspace --all-targets
}

run_full() {
    run_medium

    if [[ "$RUN_FUZZ_TARGETS" == "yes" ]]; then
        # 60s per target × ~21 targets = ~20 min. Skips with a clear
        # message when nightly rustc / cargo-fuzz isn't available
        # (matches the existing `check-fuzz-targets` posture).
        run "Fuzz crash-regression gate" "$ROOT_DIR/scripts/run-fuzz-corpus" --time 60
    fi

    if [[ "$RUN_SECURITY" == "yes" ]]; then
        run "Security audit" "$ROOT_DIR/scripts/check-security"
    fi

    if [[ "$RUN_COVERAGE" == "yes" ]]; then
        run "Coverage gate" "$ROOT_DIR/scripts/check-coverage"
    fi

    if [[ "$RUN_TLA" == "yes" ]]; then
        run "TLA+ gate" "$ROOT_DIR/scripts/check-tla"
    fi

    if [[ "$RUN_MEMORY_SAFETY" == "yes" ]]; then
        run "Memory-safety gate" "$ROOT_DIR/scripts/check-memory-safety"
    fi

    if [[ "$RUN_PERF" == "yes" ]]; then
        run "Deterministic benchmark gate" "$ROOT_DIR/scripts/bench-deterministic"
    fi

    if [[ "$RUN_CROSS" == "yes" ]]; then
        run "Docker cross-arch matrix" "$ROOT_DIR/scripts/ci-cross-docker"
        return
    fi

    if [[ "$RUN_CROSS" == "auto" ]] && command -v docker >/dev/null 2>&1; then
        echo ""
        echo "=== Docker cross-arch matrix (auto) ==="
        "$ROOT_DIR/scripts/ci-cross-docker" || {
            echo "WARNING: docker cross-arch matrix failed."
            echo "Run with '--no-cross' to skip, or fix docker environment."
            exit 1
        }
    fi
}

case "$TIER" in
    fast)
        run_fast
        ;;
    medium)
        run_medium
        ;;
    full)
        run_full
        ;;
    *)
        echo "Invalid tier: $TIER" >&2
        usage
        exit 2
        ;;
esac

echo ""
echo "Tier '$TIER' completed successfully."
